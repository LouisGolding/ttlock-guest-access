# Copy this file to ttlock.env and fill in your own values.
# ttlock.env is gitignored — NEVER commit real credentials.

# From your app on the TTLock Open Platform (https://open.ttlock.com
# or https://euopen.ttlock.com for the EU region)
TTLOCK_CLIENT_ID=your-client-id
TTLOCK_CLIENT_SECRET=your-client-secret

# The TTLock account that owns/administers the locks
TTLOCK_USERNAME=your-ttlock-account-email
TTLOCK_PASSWORD=your-ttlock-account-password

# Optional: API server region. Default is the EU server.
# TTLOCK_BASE=https://euapi.ttlock.com
